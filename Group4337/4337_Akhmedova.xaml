<Window x:Class="Group4337._4337_Akhmedova"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Group4337"
        mc:Ignorable="d"
        Title="_4337_Akhmedova" Height="450" Width="800" Background="SkyBlue">
    <Grid >
        <TextBlock Foreground="Fuchsia" FontSize="30" Text="Алия" Margin="50,40,0,0"/>
        <TextBlock Foreground="Fuchsia" FontSize="30" Text="18!" Margin="120,40,0,0"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="11*"/>
            </Grid.RowDefinitions>
            <UniformGrid Grid.Row="0" Columns="4">
                <Button x:Name="BnExport" Background="Fuchsia" FontWeight="Black" FontSize="16px" Foreground="BlueViolet" Click="BnExport_Click">Экспорт в Excel</Button>
                <Button x:Name="BnImport" Background="Fuchsia" FontWeight="Black" FontSize="16px" Foreground="BlueViolet" Click="BnImport_Click">Импорт данных</Button>
                <Button x:Name="BnExportWord" Background="Fuchsia" FontWeight="Black" FontSize="16px" Foreground="BlueViolet" Click="BnExportWord_Click">Экспорт в Word</Button>
                <Button x:Name="BnImportJSON" Background="Fuchsia" FontWeight="Black" FontSize="16px" Foreground="BlueViolet" Click="BnImportJSON_Click">Импорт JSON</Button>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>